{
  "state_file": ".state/docker-version-bot.json",
  "backfill_missing_versions": false,
  "allow_v_prefix_alias": true,
  "on_existing_digest_change": "update_existing",
  "dockerhub_page_size": 100,
  "dockerhub_max_pages": 10,
  "github_max_pages": 5,
  "max_new_versions_per_app": 1,
  "git_user_name": "github-actions[bot]",
  "git_user_email": "github-actions[bot]@users.noreply.github.com",
  "commit_message": "chore: sync docker image versions",
  "apps": [
    {
      "app": "rainbow-dnsmgr",
      "enabled": true,
      "mode": "github_release",
      "github_repo": "netcccyun/dnsmgr",
      "image": "netcccyun/dnsmgr",
      "track_tag": "latest",
      "pin_digest": true,
      "source_version": "latest",
      "include_regex": "^v?\\d+\\.\\d+(\\.\\d+)?$",
      "exclude_regex": "(alpha|beta|rc|dev|nightly|snapshot)",
      "version_dir_template": "{clean_github_tag}",
      "max_new_versions": 1,
      "backfill_missing_versions": false,
      "on_existing_digest_change": "update_existing",
      "cleanup_old_versions": true,
      "keep_latest_versions": 3,
      "preserve_versions": [
        "latest"
      ],
      "cleanup_include_regex": "^v?\\d+\\.\\d+(\\.\\d+)?$",
      "fallback_to_github_tags": true,
      "require_image_match": true,
      "cleanup_when_no_candidates": false,
      "official_versions_source_of_truth": false
    },
    {
      "app": "next-terminal",
      "enabled": true,
      "mode": "docker_tag",
      "image": "dushixiang/next-terminal",
      "source_version": "latest",
      "include_regex": "^v?\\d+\\.\\d+\\.\\d+$",
      "exclude_regex": "(alpha|beta|rc|dev|nightly|snapshot|preview|canary|test|b\\d+)",
      "version_dir_template": "{clean_tag}",
      "max_new_versions": 1,
      "backfill_missing_versions": false,
      "cleanup_old_versions": true,
      "keep_latest_versions": 3,
      "preserve_versions": [
        "latest"
      ],
      "cleanup_include_regex": "^v?\\d+\\.\\d+\\.\\d+$",
      "require_image_match": true,
      "cleanup_when_no_candidates": false,
      "official_versions_source_of_truth": false
    },
    {
      "app": "mtab",
      "enabled": true,
      "mode": "docker_tag",
      "image": "itushan/mtab",
      "source_version": "auto",
      "include_regex": "^v?\\d+\\.\\d+\\.\\d+$",
      "exclude_regex": "(alpha|beta|rc|dev|nightly|snapshot|preview|canary|test|b\\d+)",
      "version_dir_template": "{clean_tag}",
      "max_new_versions": 1,
      "backfill_missing_versions": false,
      "cleanup_old_versions": true,
      "keep_latest_versions": 3,
      "preserve_versions": [
        "latest"
      ],
      "cleanup_include_regex": "^v?\\d+\\.\\d+\\.\\d+$",
      "require_image_match": true,
      "cleanup_when_no_candidates": false,
      "skip_older_than_existing": false,
      "official_versions_source_of_truth": true,
      "prune_unofficial_versions": true
    }
  ],
  "cleanup_old_versions": true,
  "keep_latest_versions": 3,
  "preserve_versions": [
    "latest"
  ],
  "cleanup_include_regex": "^v?\\d+\\.\\d+(\\.\\d+)?$",
  "fallback_to_github_tags": true,
  "require_image_match": true,
  "cleanup_when_no_candidates": false,
  "skip_older_than_existing": true,
  "official_versions_source_of_truth": false
}
